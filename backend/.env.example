# ── sensor.py 설정 (로컬 PC에서 사용) ────────────────────────────
# 실행 전 이 파일을 .env로 복사 후 값 채우기

# Oracle 서버 WebSocket 주소
SERVER_WS=ws://<서버_공인IP>:8000/sensor

# 구역 정보 (여러 현장 기기 사용 시 각각 다르게 설정)
ZONE_ID=zone-001
ZONE_NAME=폐공사장 A구역
ZONE_COORD=37.5665° N, 126.9780° E
ZONE_ADDR=폐공사장 A구역 입구

# 오디오 설정 (변경 불필요)
SAMPLE_RATE=16000
CHUNK_SECONDS=5
